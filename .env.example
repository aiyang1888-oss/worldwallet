# Copy to .env — never commit .env
# ============================================================

# Telegram（与 orchestrator / telegram-notifier 一致时可用 TG_* 或下列名称）
TG_BOT_TOKEN=
TG_CHAT_ID=

# 你的 Telegram Bot Token（@BotFather）
# 获取方式：在 Telegram 中找 @BotFather，创建新 bot 获得 token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 你的 Chat ID（接收通知）
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates 中 "chat":{"id":...}
TELEGRAM_CHAT_ID=your_chat_id_here

# 可选：cursor-agent 路径（auto-dispatch.sh 默认 ~/.local/bin/cursor-agent）
CURSOR_AGENT=

# 可选：通知开关（若 telegram-notifier 支持）
TELEGRAM_NOTIFY_PHASE_START=true
TELEGRAM_NOTIFY_PHASE_COMPLETE=true
TELEGRAM_NOTIFY_ERRORS=true
TELEGRAM_NOTIFY_FINAL=true
