# Copy to .env (gitignored) and fill in. Get token from @BotFather; chat id from @userinfobot or getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set to 1 to send a Telegram message after each local git commit (via scripts/install-telegram-git-hook.sh)
TELEGRAM_NOTIFY_ON_COMMIT=1

# --- Telegram 内联按钮遥控本机 Cursor（可选）---
# 与本仓库同机长期运行: npm run telegram:cursor
# 仅当为 1 时启动 scripts/telegram-cursor-control.mjs（防误跑）
TELEGRAM_CONTROL_ENABLED=1
# 要打开的项目根目录（默认本仓库根目录）
# CURSOR_WORKSPACE=/absolute/path/to/WorldWallet

# macOS 开机/登录自启（LaunchAgent）：npm run telegram:launchagent:install

# 若遥控脚本找不到 cursor 命令（LaunchAgent 环境），填写可执行文件绝对路径
# CURSOR_CLI_PATH=/Users/you/.local/bin/cursor
